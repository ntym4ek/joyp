{#
/**
 * @file
 * Two column template for the checkout form.
 *
 * Available variables:
 * - form: The form.
 *
 * @ingroup themeable
 */
#}
<div class="row">
  <div class="col-sm-10 col-pd-10 col-tb-10 col-lp-7 col-dt-7 col-wd-7 col-no-gutter main">
    {{ form|without('sidebar', 'actions') }}
  </div>
  {% if form["#step_id"] != "complete" %}
  <div class="col-sm-10 col-pd-10 col-tb-10 col-lp-3 col-dt-3 col-wd-3 sidebar">
    <div class="float-wrapper">
      <h3>Ваш заказ</h3>
      {{ form.sidebar }}
      {{ form.actions }}
    </div>
  </div>
  {% endif %}
</div>
