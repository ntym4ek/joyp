{#
/**
 * @file
 *
 * Default template for product variations.
 *
 * Available variables:
 * - attributes: HTML attributes for the wrapper.
 * - product_variation: The rendered product variation fields.
 *   Use 'product_variation' to print them all, or print a subset such as
 *   'product_variation.title'. Use the following code to exclude the
 *   printing of a given field:
 *   @code
 *   {{ product_variation|without('title') }}
 *   @endcode
 * - product_variation_entity: The product variation entity.
 * - product_url: The product URL.
 * - product_variation_url: The product variation URL.
 * - is_active: Whether the current variation is the active variation.
 *
 * @ingroup themeable
 */
#}
{% set classes = ['product', 'product--teaser'] %}
{% if product_variation.category_id  %}
  {% set classes = classes|merge(['product-category--' ~ product_variation.category_id|raw ]) %}
{% endif %}
{% if not product_variation.availability.is_available  %}
  {% set classes = classes|merge(['product--unavailable']) %}
{% endif %}

<div{{ attributes.addClass(classes) }}>
  <div class="product__inner">
    <div class="product__image">
      {{- product_variation.field_pv_images[0] -}}
      {% if product_variation.discount %}
        <div class="product__discount">
          {{- product_variation.discount -}}
        </div>
      {% endif %}
    </div>
    <div class="product__content">
      <div class="product__title">
        <a href="{{ product_variation_url }}"><h4>{{- product_variation.title -}}</h4></a>
        {% if product_variation.availability.is_available %}
          {{ product_variation.commerce_variation_cart_form }}
        {% endif %}
      </div>
      <div class="product__volume">{{- product_variation.attribute_volume -}}</div>
      <div class="product__price">
        {{- product_variation.price -}}
        {% if product_variation.availability.is_available %}
          {{- product_variation.list_price -}}
        {% else %}
          <div class="product__stock">
            {{ product_variation.availability.stock_status }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>
