<div class="row border-t">
  <div class="col-xs-10 col-md-10">
    <div class="section-title">
      <h2>Каталог товаров</h2>
    </div>
  </div>
</div>

<div class="content">
  <div class="row border-t">
    {% for category in categories %}
    <div class="col-xs-10 col-md-2">
      <a href="{{ category.url }}">
        <div class="category-card">
          <div class="category-card__image">
            <div class="image"><img src="{{ category.image.url }}" alt="{{ category.title }}"></div>
          </div>
          <div class="category-card__title"><h4>{{ category.title }}</h4></div>
          <div class="category-card__more"><i class="picon picon--arrow-right"></i></div>
        </div>
      </a>
    </div>
    {% endfor %}
  </div>
</div>

