      <ul class="menu">
        <li><a href="{{ path('entity.taxonomy_term.canonical', {'taxonomy_term': 26}) }}">Подарочные наборы</a></li>
        <li><a href="{{ path('entity.taxonomy_term.canonical', {'taxonomy_term': 21}) }}">Для волос</a></li>
        <li><a href="{{ path('entity.taxonomy_term.canonical', {'taxonomy_term': 22}) }}">Для рук</a></li>
