        <a href="{{ path('entity.node.canonical', {'node': 13}) }}" class="button button--primary">Задать вопрос</a>
      </div>
    </div>
  </div>

  <div class="page"{{ attributes }}>
    <header class="page-header" role="banner">
      <div class="page-header__inner">

        <div class="page-header__row">
          <div class="container-fluid">
            <div class="page-header__content">

              <div class="page-header__col11">
                <div class="page-header__brand">
                  <div class="branding">
                    <div class="branding__logo"><a href="/"><img src="{{ site.logo.standart }}" alt="JOY PREMIUM" /></a></div>
                  </div>
                </div>
              </div>


              <div class="page-header__col12 hide-xl">
                <div class="page-header__item">
                  <a href="/user"><i class="picon picon--account"></i></a>
                </div>

                <div class="page-header__item">
                  {{ cart_block }}
                </div>

                <div class="page-header__item">
                  <div class="page-offside-label">
                    <i class="picon picon--menu"></i>
                  </div>
                </div>
              </div>

            </div>
          </div>
        </div>

        <div class="page-header__row hide show-xl">
          <div class="container-fluid">
            <div class="page-header__content">

              <div class="page-header__col21">
                <div class="page-header__menu">
                  <div class="menu-wrapper">
                    {{ page.primary_menu }}
                  </div>
                </div>
              </div>

              <div class="page-header__col22">
                <div class="page-header__item">
                  8 922 922-67-74
                </div>

                <div class="page-header__menu">
                  <div class="menu-wrapper">
                    {{ page.secondary_menu }}
                  </div>
                </div>

                <div class="page-header__item">
                  {{ cart_block }}
                </div>
              </div>
            </div>

          </div>
        </div>

      </div>
    </header>

    <div class="page-content">
      <div class="container-fluid">
        {{ page.header }}

        {{ page.breadcrumb }}

        <div class="page-main">
          {{ page.highlighted }}

          <div class="row">
            {% if page.sidebar_first %}
              <aside class="col-xs-10 col-xl-{{ sidebar_first_col }}" role="complementary">
                {{ page.sidebar_first }}
              </aside>
            {% endif %}

            <main class="col-xs-10 col-xl-fill" role="main">
              {{ page.content }}
            </main>

            {% if page.sidebar_second %}
              <aside class="col-xs-10 col-xl-{{ sidebar_second_col }}" role="complementary">
                {{ page.sidebar_second }}
              </aside>
            {% endif %}
          </div>

        </div>

        {{ page.downlighted }}

      </div>
    </div>

    {# {{ page.help }}  #}

