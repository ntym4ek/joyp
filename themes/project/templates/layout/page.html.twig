        <li><a href="/">Сертификаты</a></li>
      </ul>
    </div>

    <div class="page-offside__footer">
      <div class="page-offside__row">
        <ul class="menu">
          <li><a href="tel:+79229226774">8 (922) 922-67-74</a></li>
          <li><a href="mailto:joypremium_zakaz@kccc.ru">joypremium_zakaz@kccc.ru</a></li>
        </ul>
      </div>
      <div class="page-offside__row">
        <ul class="menu menu--info">
          <li><a href="{{ path('entity.node.canonical', {'node': 12}) }}">Согласие на обработку персональных данных</a></li>
          <li><a href="/sites/default/files/attachments/misc/personal-data-policy.pdf" title="Файл в формате PDF">Политика в отношении обработки персональных данных</a></li>
          <li><a href="{{ path('entity.node.canonical', {'node': 3}) }}">Политика конфиденциальности</a></li>
          <li><a href="{{ path('entity.node.canonical', {'node': 11}) }}">Договор публичной оферты</a></li>
