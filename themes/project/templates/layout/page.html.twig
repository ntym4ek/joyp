                  <ul>
                    <li><a href="tel:+79229226774">8 (922) 922-67-74</a></li>
                    <li><a href="mailto:joypremium_zakaz@kccc.ru">joypremium_zakaz@kccc.ru</a></li>
                    <li class="hide show-xl"><a href="{{ path('entity.node.canonical', {'node': 13}) }}" class="button button--primary">Задать вопрос</a></li>
                  </ul>
                </div>
              </div>
              <div class="col-md-5 hide show-md-only">
                <a href="{{ path('entity.node.canonical', {'node': 13}) }}" class="button button--primary">Задать вопрос</a>
              </div>
            </div>
          </div>
        </div>
        <div class="page-footer__row2">
          <div class="container-fluid">
            <div class="row">
              <div class="col-xs-10 col-md-10 col-xl-8">
                <div class="production">
