<?php

require('includes/extn_commerce.cart.inc');
require('includes/extn_commerce.checkout.inc');

const SHIPPING_COURIER = 1;
const SHIPPING_PICKUP = 2;

use Drupal\Core\Form\FormStateInterface;

/**
 * Implements hook_form_alter()
 */
function extn_commerce_form_alter(&$form, FormStateInterface $form_state, $form_id): void
{
  // форма Корзины
  if (str_contains($form_id, 'views_form_commerce_cart_form')) {
    extn_commerce_cart_form_alter($form, $form_state);
  }
}



